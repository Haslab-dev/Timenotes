# Turso Database Configuration (Required)
VITE_TURSO_DATABASE_URL=libsql://your-database-name.turso.io
VITE_TURSO_AUTH_TOKEN=your-auth-token-here

# Qdrant Hybrid Search (Required for semantic search)
VITE_QDRANT_URL=https://your-cluster.qdrant.io
VITE_QDRANT_API_KEY=your-qdrant-api-key
VITE_QDRANT_COLLECTION=timenotes

# Embedding Provider (Required for hybrid search)
# Works with any OpenAI-compatible endpoint: Maiarouter, OpenAI, Together AI, Ollama, etc.
VITE_EMBEDDING_API_KEY=your-api-key
VITE_EMBEDDING_API_URL=https://api.maiarouter.ai/v1
VITE_EMBEDDING_MODEL=openai/text-embedding-3-large
VITE_EMBEDDING_DIMENSIONS=3072

# OpenAI (Fallback for embeddings if VITE_EMBEDDING_API_KEY not set)
VITE_OPENAI_API_KEY=your-openai-api-key

# Environment
NODE_ENV=development
